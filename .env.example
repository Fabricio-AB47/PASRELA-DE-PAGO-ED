DEBUG=0
SECRET_KEY=replace-with-at-least-64-random-characters
DJANGO_ALLOWED_HOSTS=replace-me
DJANGO_CSRF_TRUSTED_ORIGINS=replace-me
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
PAYMENTS_API_URL=replace-me
TOKEN_PAY=replace-in-secret-store
PAYMENTS_AMBIENTE=Produccion
PAYMENTS_CACHE_TTL=300
PAYMENTS_AUTO_RECONCILE_SECONDS=60
PAYMENTS_TRANSACTION_URL_TEMPLATE=replace-me
DB_ENGINE=mssql
DB_NAME=replace-me
DB_USER=replace-me
DB_PASSWORD=replace-me
DB_HOST=replace-me
DB_PORT=1433
DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server
# Conexión independiente para base de complemneto. DB_ENGIN1 se acepta por
# compatibilidad, pero DB_ENGINE1 es el nombre recomendado.
DB_ENGINE1=mssql
DB_NAME1=replace-me
DB_USER1=replace-me
DB_PASSWORD1=replace-me
DB_HOST1=replace-me
DB_PORT1=1433
DB_ODBC_DRIVER1=ODBC Driver 18 for SQL Server
DB_ODBC_EXTRA_PARAMS1=Encrypt=yes;TrustServerCertificate=yes
EDU_CONTINUA_ENABLED=1
EDU_CONTINUA_DB_NAME=replace-me
MS_TENANT_ID=replace-me
MS_CLIENT_ID=replace-me
MS_CLIENT_SECRET=replace-in-secret-store
