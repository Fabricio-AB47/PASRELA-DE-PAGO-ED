<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <remove name="Cache-Control" />
        <remove name="Pragma" />
        <remove name="Expires" />
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        <add name="Pragma" value="no-cache" />
        <add name="Expires" value="0" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="same-origin" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=()" />
        <add name="Content-Security-Policy" value="default-src 'self'; base-uri 'self'; frame-ancestors 'none'; frame-src 'self' blob:; form-action 'self'; object-src 'none'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self';" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <rule name="Redirect HTTPS 446 to canonical HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="on" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^ed-continua-inova\.intec\.edu\.ec:446$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://ed-continua-inova.intec.edu.ec/{R:1}" redirectType="Permanent" />
        </rule>

        <rule name="Redirect HTTP to canonical HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^ed-continua-inova\.intec\.edu\.ec(?::80)?$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://ed-continua-inova.intec.edu.ec/{R:1}" redirectType="Permanent" />
        </rule>

        <rule name="Proxy API Django" stopProcessing="true">
          <match url="^api/(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
          <action type="Rewrite" url="http://127.0.0.1:8000/api/{R:1}" />
        </rule>

        <rule name="Proxy Admin Django" stopProcessing="true">
          <match url="^admin/(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
          <action type="Rewrite" url="http://127.0.0.1:8000/admin/{R:1}" />
        </rule>

        <rule name="Proxy Media Django" stopProcessing="true">
          <match url="^media/(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
          <action type="Rewrite" url="http://127.0.0.1:8000/media/{R:1}" />
        </rule>

        <rule name="React SPA Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
